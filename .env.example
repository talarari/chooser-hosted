# Copy to .env and fill in to deploy from your machine:  cp .env.example .env
#
# Create a token at https://dash.cloudflare.com/profile/api-tokens with the
# "Edit Cloudflare Workers" template (Workers Scripts + Workers KV + Durable
# Objects). The account ID is on any Workers page in the dashboard.
#
# .env is gitignored and loaded automatically by `npm run deploy`. In CI these
# are GitHub Actions secrets instead (see .github/workflows/deploy.yml).

export CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
export CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
